{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "functions": {
    "app/**": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/automation/full-content-automation",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/automation/seo-sync",
      "schedule": "0 6 * * *"
    }
  ]
}