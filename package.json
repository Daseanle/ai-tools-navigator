{
  "name": "ai-tools-navigator",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://ai-tools-navigator.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/ai-tools-navigator.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "node -r ./global-polyfill.js ./node_modules/.bin/next build",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "deploy:supabase": "./scripts/deploy-supabase.sh",
    "import:data": "./scripts/import-data.sh",
    "setup:env": "cp .env.local.example .env.local",
    "build:analyze": "ANALYZE=true next build",
    "export": "next build && next export",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out",
    "production:build": "npm run clean && npm run type-check && npm run build",
    "automation:start": "node scripts/start-automation.js",
    "automation:dev": "node scripts/start-automation.js --dev",
    "automation:status": "curl http://localhost:3000/api/automation/status",
    "perf:audit": "lighthouse --chrome-flags='--headless' --output=json --output-path=./lighthouse-results.json http://localhost:3000",
    "perf:bundle": "npm run build:analyze",
    "db:optimize": "./scripts/optimize-database.sh",
    "db:refresh-stats": "./scripts/refresh-materialized-views.sh",
    "monitor:start": "npm run dev & npm run monitor:health",
    "monitor:health": "while true; do curl -f http://localhost:3000/api/monitoring/metrics > /dev/null 2>&1 && echo 'Health check passed' || echo 'Health check failed'; sleep 30; done",
    "postinstall": "echo 'Project installed successfully'"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "latest",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "latest",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.5.1",
    "framer-motion": "latest",
    "global": "^4.4.0",
    "googleapis": "^150.0.1",
    "input-otp": "1.4.1",
    "ioredis": "^5.6.1",
    "lru-cache": "^11.1.0",
    "lucide-react": "^0.454.0",
    "next": "14.2.16",
    "next-themes": "^0.4.4",
    "openai": "^5.8.3",
    "process": "^0.11.10",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-day-picker": "8.10.1",
    "react-dom": "^18",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "speakeasy": "^2.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.6",
    "web-push": "^3.6.7",
    "zod": "^3.25.74",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "lodash": "^4.17.21",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "web-vitals": "^3.5.2",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
